#!/usr/bin/env bash
# Configure host resolution without breaking Docker mount restrictions

# /etc/hosts faylını sed -i etmədən, təhlükəsiz şəkildə oxuyub dəyişirik və birbaşa üzərinə yazırıq
sed 's/127.0.0.1/127.0.0.2/g' /etc/hosts > /etc/hosts.tmp && cat /etc/hosts.tmp > /etc/hosts && rm -f /etc/hosts.tmp

# Əgər facebook.com yoxdursa əlavə edirik, varsa yeniləyirik
if ! grep -q "facebook.com" /etc/hosts; then
    echo "8.8.8.8 facebook.com" >> /etc/hosts
else
    sed 's/.*facebook.com/8.8.8.8 facebook.com/g' /etc/hosts > /etc/hosts.tmp && cat /etc/hosts.tmp > /etc/hosts && rm -f /etc/hosts.tmp
fi
